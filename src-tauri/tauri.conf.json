{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lunachat",
  "version": "1.0.3",
  "identifier": "com.lunachat.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LunaChat",
        "width": 1360,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kretuno/-lunachat-/releases/latest/download/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1NThBQjI0NkEzRUI0ODgKUldTSXRENXFKS3RZRmZzb0ZaZUlyUHNINGU0L09PQmhLS1JlL2ZXRlJ5azZrWWN4VU9XK0hQcjAK"
    }
  }
}
